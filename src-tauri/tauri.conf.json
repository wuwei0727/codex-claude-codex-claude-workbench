{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Claude Workbench",
  "version": "0.1.0",
  "identifier": "com.codexclaudeworkbench.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Claude Workbench",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": null
      }
    }
  }
}

